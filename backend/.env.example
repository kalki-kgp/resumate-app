# ResuMate Backend Configuration
# Copy this to .env and fill in your values

PROJECT_NAME=ResuMate API
VERSION=0.1.0
DATABASE_URL=postgresql+psycopg://resumate:resumate@localhost:5432/resumate
BACKEND_CORS_ORIGINS=http://localhost:3000
AUTH_SESSION_TTL_HOURS=720
UPLOAD_DIR=uploads
MAX_RESUME_UPLOAD_SIZE_MB=8

# VLM Provider: "nebius" or "chutes"
RESUME_IMAGE_PROCESSING_PROVIDER=nebius

# Nebius (default provider) - get your key from Nebius AI Studio
NEBIUS_API_KEY=
NEBIUS_BASE_URL=
NEBIUS_MODEL=google/gemma-3-27b-it-fast

# Chutes (alternative provider)
CHUTES_API_TOKEN=
CHUTES_BASE_URL=
CHUTES_MODEL=

# Analysis tuning
RESUME_ANALYSIS_DEBUG=false
RESUME_ANALYSIS_MAX_PAGES=2
RESUME_ANALYSIS_MAX_TOKENS=30000
RESUME_ANALYSIS_TEMPERATURE=0.35
RESUME_EXTRACTION_MAX_TOKENS=30000
RESUME_EXTRACTION_TEMPERATURE=0.2
RESUME_FILL_TEMPLATE_MAX_TOKENS=30000
RESUME_FILL_TEMPLATE_TEMPERATURE=0.15
RESUME_ANALYSIS_TOP_P=0.9
RESUME_ANALYSIS_TOP_K=50
RESUME_RENDER_SCALE=1.6
RESUME_RENDER_MAX_WIDTH=1400

# Template fill provider: "nebius" or "chutes"
RESUME_FILL_PROVIDER=nebius
NEBIUS_FILL_MODEL=deepseek-ai/DeepSeek-V3-0324-fast
CHUTES_FILL_MODEL=

# AI Write assist
AI_WRITE_MAX_TOKENS=2000
AI_WRITE_TEMPERATURE=0.7

# Cover letter
COVER_LETTER_MAX_TOKENS=3000
COVER_LETTER_TEMPERATURE=0.7
